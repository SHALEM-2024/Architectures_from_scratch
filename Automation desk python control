import win32com.client
import time

# 1. Start AutomationDesk in the background (headless via COM)
print("Starting AutomationDesk...")
ad = win32com.client.Dispatch("AutomationDesk.Application")
ad.Visible = False # Keeps the GUI hidden

try:
    # 2. Open your project
    project_path = r"C:\dSPACE_Projects\MyProject\MyProject.adx"
    print(f"Loading project: {project_path}")
    project = ad.OpenProject(project_path)

    # 3. Locate and execute the test sequence
    test_sequence = project.GetItem("Test_Sequence_1")
    print("Executing tests...")
    execution = test_sequence.Execute()

    # 4. Wait for completion
    while execution.Status == "Running":
        time.sleep(2)
        
    print(f"Test finished with status: {execution.Status}")

    # 5. Export the report
    report = execution.GetReport()
    report.Export(r"C:\dSPACE_Projects\Reports\latest_run.pdf", "PDF")

finally:
    # 6. Ensure AutomationDesk closes completely
    ad.Quit()
    print("AutomationDesk closed.")
